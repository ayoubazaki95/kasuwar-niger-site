# Connexion admin (tableau de bord /admin)
NEXT_PUBLIC_ADMIN_EMAIL=votre-email@exemple.com
NEXT_PUBLIC_ADMIN_PASSWORD_HASH=remplacez-par-un-hash-sha256

# Supabase (base de données + comptes clients)
# Trouvables dans votre projet Supabase : Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon-publique
SUPABASE_SERVICE_ROLE_KEY=votre-cle-service-role-SECRETE
